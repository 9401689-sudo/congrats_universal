    {
      "parameters": {
        "jsCode": "const row = $json;\nif (!row) throw new Error(\"Delivery row is empty\");\n\nconst deliveryId = String(row.delivery_id);\nconst documentId = String(row.document_id);\nconst requestId = String(row.request_id);\n\nconst renderParams = row.render_params ?? {};\nif (!renderParams || typeof renderParams !== \"object\") {\n  throw new Error(\"documents.render_params missing\");\n}\n\nconst deliveryMethod = String(row.delivery_method ?? row.request_delivery_method ?? \"manual\");\nconst recipientUsername = row.recipient_username ?? row.delivery_username ?? null;\nconst finalFileId = row.final_file_id ?? null;\n\nreturn [{\n  json: {\n    ...$json,\n    delivery_id: deliveryId,\n    document_id: documentId,\n    request_id: requestId,\n    delivery_method: deliveryMethod,\n    recipient_username: recipientUsername,\n    final_file_id: finalFileId,\n    render_params: renderParams\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        368
      ],
      "id": "01517c4c-a97c-496e-b49d-4540687427e7",
      "name": "FN_PREPARE_DELIVERY_CONTEXT"
    },
    {
