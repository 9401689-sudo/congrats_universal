    {
      "parameters": {
        "command": "=set -e\n/opt/razresheno/venv/bin/python /opt/razresheno/render_doc.py \"{{$json.inPath}}\"\ntest -f \"{{$json.outLocal}}\" || (echo \"NO_FINAL_FILE {{$json.outLocal}}\" >&2; exit 1)\nls -la \"{{$json.outLocal}}\""
      },
