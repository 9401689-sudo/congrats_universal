    {
      "parameters": {
        "jsCode": "const requestId = String($json.request_id);\nconst deliveryId = String($json.delivery_id);\n\nconst inPath = `/opt/razresheno/renders/tmp/delivery_${deliveryId}_final.json`;\nconst outLocal = `/opt/razresheno/renders/final/req${requestId}_delivery_${deliveryId}.png`;\n\nconst renderJson = {\n  ...($json.render_params ?? {}),\n  mode: \"final\",\n  output_path: outLocal\n};\n\nreturn [{\n  json: {\n    ...$json,\n    inPath,\n    outLocal,\n    renderJson\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1184,
        416
      ],
      "id": "9b85437a-b5f8-451a-988a-2db298ca6bf1",
