      ],
      "id": "0cf60264-1545-49e2-a2e0-9c6750dab76b",
      "name": "CMD_RENDER_FINAL_WORKER",
      "credentials": {
        "sshPassword": {
          "id": "JhAjso9ApJbtaT8r",
          "name": "SSH Password account"
        }
      }
    },
    {
      "parameters": {
        "command": "=set -e\nTOKEN=\"$(cat /opt/razresheno/secrets/tg_bot_token)\"\nFILE=\"{{$json.outLocal}}\"\nCHAT=\"{{$json.tg_user_id || ''}}\"\nOUT=\"/opt/razresheno/renders/tmp/tg_send_worker_upload_{{$json.delivery_id}}.json\"\n\nif [ -z \"$CHAT\" ]; then\n  echo \"tg_user_id is empty\" >&2\n  exit 1\nfi\n\ncurl -sS -X POST \"https://api.telegram.org/bot$TOKEN/sendDocument\" \\\n  -F \"chat_id=$CHAT\" \\\n  -F \"document=@$FILE\" \\\n  -F \"caption=Документ готов и направлен по расписанию.\" \\\n  > \"$OUT\"\n\ncat \"$OUT\""
      },
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [
        2368,
        560
      ],
      "id": "7541c890-ad13-4113-b4ca-57926c905958",
      "name": "CMD_TG_SEND_BY_UPLOAD_WORKER",
      "credentials": {
        "sshPassword": {
          "id": "JhAjso9ApJbtaT8r",
          "name": "SSH Password account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $node[\"CMD_TG_SEND_BY_UPLOAD_WORKER\"].json.stdout ?? \"\";\nif (!raw) throw new Error(\"Telegram send response empty\");\n\nlet j;\ntry {\n  j = JSON.parse(raw);\n} catch (e) {\n  throw new Error(\"Telegram response is not JSON: \" + raw.slice(0, 300));\n}\n\nif (!j.ok) {\n  throw new Error(\"Telegram send failed: \" + JSON.stringify(j));\n}\n\nconst fileId = j.result?.document?.file_id;\nconst messageId = j.result?.message_id;\n\nif (!fileId) throw new Error(\"No document.file_id in Telegram response\");\n\nreturn [{\n  json: {\n    ...$json,\n    final_file_id: fileId,\n    tg_message_id: messageId\n  }\n}];"
      },
