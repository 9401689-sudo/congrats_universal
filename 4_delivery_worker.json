    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select\n  d.id as delivery_id,\n  d.document_id,\n  d.scheduled_at,\n  d.delivery_method,\n  d.recipient_username,\n  d.sent_at,\n\n  doc.request_id,\n  doc.tariff,\n  doc.initiator_name,\n  doc.render_params,\n  doc.final_file_id,\n\n  r.delivery_method as request_delivery_method,\n  r.delivery_username,\n  r.user_id,\n  r.status as request_status,\n\n  u.tg_user_id\nfrom razreshenobot.deliveries d\njoin razreshenobot.documents doc\n  on doc.id = d.document_id\njoin razreshenobot.requests r\n  on r.id = doc.request_id\njoin razreshenobot.users u\n  on u.id = r.user_id\nwhere d.scheduled_at <= now()\n  and d.sent_at is null\norder by d.scheduled_at asc\nlimit 50;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        320,
        352
      ],
      "id": "83716d86-8d86-4ad0-8960-b50b1f4642c4",
