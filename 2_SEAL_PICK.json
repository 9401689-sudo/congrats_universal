    {
      "parameters": {
        "jsCode": "// FN_BUILD_TZ_BUTTON_FOR_TARIFFS\n\nconst tzRaw =\n  $json.timezone ??\n  ($json[0]?.timezone) ??\n  null;\n\nconst tz = (tzRaw && String(tzRaw).trim()) ? String(tzRaw).trim() : null;\n\nconst pretty = {\n  \"Europe/Moscow\": \"MSK (UTC+3)\",\n  \"Asia/Yekaterinburg\": \"Екатеринбург (UTC+5)\",\n  \"Asia/Omsk\": \"Омск (UTC+6)\",\n  \"Asia/Krasnoyarsk\": \"Красноярск (UTC+7)\",\n  \"Asia/Irkutsk\": \"Иркутск (UTC+8)\",\n  \"Asia/Yakutsk\": \"Якутск (UTC+9)\",\n  \"Asia/Vladivostok\": \"Владивосток (UTC+10)\",\n};\n\nconst tzLabel = tz ? (pretty[tz] ?? tz) : \"не установлен\";\n\nconst btnText = tz\n  ? `Часовой пояс: ${tzLabel}. Сменить?`\n  : `Часовой пояс: ${tzLabel}. Установить?`;\n\nreturn [{\n  json: {\n    ...$json,\n    tz,\n    tzLabel,\n    tz_button: { text: btnText, callback_data: \"TZ_CHANGE\" }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -736,
        928
      ],
      "id": "2d73d990-b0cb-4e94-a393-c773c7d1bcca",
      "name": "FN_BUILD_TZ_BUTTON_FOR_TARIFFS"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select nullif(trim(coalesce(timezone,'')), '') as timezone\nfrom razreshenobot.users\nwhere tg_user_id = $1\nlimit 1;",
        "options": {
          "queryReplacement": "={{ $node[\"When Executed by Another Workflow\"].json.tg_user_id }}"
