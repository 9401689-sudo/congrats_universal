    {
      "parameters": {
        "jsCode": "// 1. Получаем raw JSON варианта\nconst raw = $json.variant_raw ?? $json.data ?? null;\n\nif (!raw) {\n  throw new Error('Variant not found in Redis (expired or wrong key)');\n}\n\n// 2. Парсим JSON\nlet variant;\ntry {\n  variant = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch (e) {\n  throw new Error('Variant JSON parse failed');\n}\n\n// 3. Получаем индекс, который выбрал пользователь\nconst pickedIdx = Number(($json.callback_data || '').split(':')[1]);\n\nif (!pickedIdx) {\n  throw new Error('Invalid seal_pick_idx from callback_data');\n}\n\n// 4. Проверка соответствия индекса\nif (!variant.idx || Number(variant.idx) !== pickedIdx) {\n  throw new Error(\n    `Variant idx mismatch. Picked: ${pickedIdx}, Stored: ${variant.idx}`\n  );\n}\n\n// 5. Базовая структурная валидация\nif (!variant.template_id || !variant.content || !Array.isArray(variant.content.points)) {\n  throw new Error('Variant structure invalid');\n}\n\n// Всё валидно — возвращаем нормализованный объект\nreturn [{\n  ...$json,\n  variant,\n  variant_idx: Number(variant.idx),\n  template_id: variant.template_id,\n  intro_id: variant.content.intro_id ?? null,\n  points: variant.content.points ?? [],\n  layout: variant.layout ?? {},\n  engine_version: variant.meta?.engine_version ?? null,\n  assets_version: variant.meta?.assets_version ?? null\n}];"
      },
