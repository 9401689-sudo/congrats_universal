        "jsCode": "// SEAL_PICK__FN_PARSE_SESSION_AND_PICK\n\n// 1) seal_pick_idx\nconst cd = $json.callback_data ?? \"\";\nconst m = cd.match(/^SEAL_PICK:(\\d+)$/);\nconst seal_pick_idx = m ? Number(m[1]) : null;\n\n// 2) session parse\nconst raw =\n  $json.session ??\n  $json.redis?.session ??\n  $json.redis?.data ??\n  $json.data ??\n  $json.session_raw ??\n  null;\n\nlet sess = {};\ntry {\n  let parsed = raw;\n  if (typeof parsed === \"string\") parsed = JSON.parse(parsed);\n  if (typeof parsed === \"string\") parsed = JSON.parse(parsed);\n  if (parsed && typeof parsed === \"object\" && !Array.isArray(parsed)) sess = parsed;\n} catch (e) {\n  sess = {};\n}\n\nsess.active_request_id = sess.active_request_id ?? null;\nsess.awaiting = sess.awaiting ?? \"none\";\nsess.recipient_name = sess.recipient_name ?? null;\nsess.current_variant_idx = String(sess.current_variant_idx ?? \"0\");\nsess.last_variant_idx = String(sess.last_variant_idx ?? \"0\");\nsess.last_inline_message_id = sess.last_inline_message_id ?? null;\n\nreturn [{\n  json: {\n    ...$json,\n    seal_pick_idx,\n    session: sess,\n    active_request_id: sess.active_request_id,\n    awaiting: sess.awaiting,\n    current_variant_idx: Number(sess.current_variant_idx ?? 0),\n    last_variant_idx: Number(sess.last_variant_idx ?? 0),\n  }\n}];"
