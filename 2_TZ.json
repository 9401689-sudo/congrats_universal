    {
      "parameters": {
        "jsCode": "// FN_UPDATE_SESSION_AFTER_TZ (устойчив к потере данных после Postgres)\n\n// 1) session берём из текущего $json, а если его нет — из FN_PARSE_SESSION_PAY199\nlet session =\n  $json.session ??\n  $node[\"FN_PARSE_SESSION_PAY199\"]?.json?.session ??\n  null;\n\nif (!session || typeof session !== \"object\") session = {};\n\n// 2) active_request_id не теряем (тоже пытаемся восстановить из FN_PARSE_SESSION_PAY199)\nsession.active_request_id =\n  session.active_request_id ??\n  $json.active_request_id ??\n  $node[\"FN_PARSE_SESSION_PAY199\"]?.json?.session?.active_request_id ??\n  null;\n\n// 3) timezone берём напрямую из FN_EXTRACT_TZ\nconst iana_tz = String($node[\"FN_EXTRACT_TZ\"]?.json?.iana_tz ?? \"\").trim();\n\nif (!iana_tz) {\n  return [{\n    json: {\n      ...$json,\n      fatal: true,\n      fatal_reason: \"EMPTY_IANA_TZ_FROM_FN_EXTRACT_TZ\",\n      session,\n    }\n  }];\n}\n\n// 4) сохраняем TZ в session\nsession.initiator_timezone = iana_tz;\n\n// 5) FSM возвращаем в обычный режим\nsession.awaiting = \"none\";\n\n// 6) tariff_pending оставляем (считываем из session, который восстановили)\nlet tariff_pending = session.tariff_pending ?? null;\nif (tariff_pending !== null && tariff_pending !== undefined && tariff_pending !== \"\") {\n  tariff_pending = Number(tariff_pending);\n  if (Number.isNaN(tariff_pending)) tariff_pending = null;\n} else {\n  tariff_pending = null;\n}\n\n// 7) дефолты\nsession.current_variant_idx = session.current_variant_idx ?? \"0\";\nsession.last_variant_idx = session.last_variant_idx ?? \"0\";\nsession.recipient_name = session.recipient_name ?? null;\n\n// в конце, перед return\nsession.tariff_pending =\n  session.tariff_pending === null || session.tariff_pending === undefined || session.tariff_pending === \"\"\n    ? null\n    : Number(session.tariff_pending);\n\nif (Number.isNaN(session.tariff_pending)) session.tariff_pending = null;\n\nreturn [{\n  json: {\n    ...$json,\n    session,\n    tariff_pending,\n    iana_tz,\n    fatal: false,\n  }\n}];"
      },
