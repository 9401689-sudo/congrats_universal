    {
      "parameters": {
        "jsCode": "const session = $json.session ?? null;\nconst tariffPending = Number(session?.tariff_pending ?? 0);\n\nconst hasActive = !!session?.active_request_id;\n\n// Если это контекст оплаты 199 — active_request_id обязателен\nif (!hasActive && tariffPending === 199) {\n  return [{\n    json: {\n      ...$json,\n      fatal: true,\n      fatal_reason: \"NO_ACTIVE_REQUEST_ID_FOR_199\",\n    }\n  }];\n}\n\n// Если это ручная смена TZ — active_request_id может отсутствовать\nreturn [{\n  json: {\n    ...$json,\n    fatal: false,\n    has_active_request_id: hasActive,\n    tariff_pending: tariffPending || null\n  }\n}];"
      },
