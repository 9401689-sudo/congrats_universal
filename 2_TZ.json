      "parameters": {
        "jsCode": "// FN_EXTRACT_TZ (safe for your normalized router)\n\n// Берём callback_data из текущего item (после SWITCH_CALLBACK)\n// либо из нормализованного апдейта\nconst cb =\n  $json.callback_data ??\n  $node[\"FN_NORMALIZE\"].json.callback_data ??\n  \"\";\n\n// tg_user_id тоже берём из нормализации (она всегда есть)\nconst tg_user_id =\n  $json.tg_user_id ??\n  $node[\"FN_NORMALIZE\"].json.tg_user_id ??\n  null;\n\nif (!tg_user_id) {\n  return [{ json: { ...$json, fatal: true, fatal_reason: \"NO_TG_USER_ID\" } }];\n}\n\nif (typeof cb !== \"string\" || !cb.startsWith(\"TZ:\")) {\n  return [{ json: { ...$json, fatal: true, fatal_reason: \"NOT_TZ_CALLBACK\", cb } }];\n}\n\nconst iana_tz = cb.slice(3).trim();\n\nif (!iana_tz) {\n  return [{ json: { ...$json, fatal: true, fatal_reason: \"EMPTY_TZ\" } }];\n}\n\nreturn [{\n  json: {\n    ...$json,\n    fatal: false,\n    tg_user_id,\n    iana_tz\n  }\n}];"
      },
