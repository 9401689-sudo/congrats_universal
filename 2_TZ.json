      "parameters": {
        "jsCode": "let session = $json.session;\nif (!session || typeof session !== \"object\") session = {};\n\n// active_request_id не теряем\nsession.active_request_id =\n  session.active_request_id ??\n  $json.active_request_id ??\n  $json.session?.active_request_id ??\n  null;\n\n// очищаем pending\nsession.tariff_pending = null;\n\n// на всякий случай выходим из режима ожидания TZ\nif (session.awaiting === \"tz\") {\n  session.awaiting = \"none\";\n}\n\n// дефолты структуры (чтобы дальше не ломались ноды, которые ожидают поля)\nsession.current_variant_idx = session.current_variant_idx ?? \"0\";\nsession.last_variant_idx = session.last_variant_idx ?? \"0\";\nsession.recipient_name = session.recipient_name ?? null;\nsession.initiator_timezone = session.initiator_timezone ?? null;\n\nreturn [{ json: { ...$json, session } }];"
