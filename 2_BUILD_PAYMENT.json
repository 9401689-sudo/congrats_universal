      "parameters": {
        "jsCode": "const session = $json.session ?? {};\n\n// 1) selected_variant_idx берём из текущего item, а не из PG\nconst selectedIdx = Number(\n  $json.selected_variant_idx ??\n  session.selected_variant_idx ??\n  session.current_variant_idx ??\n  session.last_variant_idx ??\n  1\n) || 1;\n\n// 2) variant из Redis GET (у тебя он реально приходит как value)\nconst redisOut = $node[\"REDIS_GET_SELECTED_VARIANT\"]?.json ?? {};\nconst raw = redisOut.value ?? redisOut.data ?? redisOut.result ?? null;\n\nif (!raw) throw new Error(\"Selected variant missing in Redis\");\n\nlet variant_snapshot;\nif (typeof raw === \"object\" && raw !== null) {\n  variant_snapshot = raw;\n} else {\n  const s = String(raw).trim();\n  if (!s) throw new Error(\"Redis returned empty string\");\n  variant_snapshot = JSON.parse(s);\n}\n\nreturn [{\n  json: {\n    ...$json,\n    selected_variant_idx: selectedIdx,\n    tg_user_id: String(session.tg_user_id ?? $json.tg_user_id ?? \"\"),\n    initiator_name: String(session.tg_first_name ?? \"\").trim() || \"Инициатор\",\n    variant_snapshot\n  }\n}];"
