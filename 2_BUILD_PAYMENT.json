      "parameters": {
        "jsCode": "const session = $json.session ?? {};\nconst reqId = String(session.active_request_id ?? \"0\");\nconst tg = String(session.tg_user_id ?? \"0\");\n\n// без crypto: Date.now + Math.random, но детерминировать не надо — просто уникально\nconst key = `${Date.now()}_${Math.floor(Math.random()*1e9)}_r${reqId}_u${tg}`;\n\nreturn [{\n  json: {\n    ...$json,\n    yk_idempotence_key: key\n  }\n}];"
