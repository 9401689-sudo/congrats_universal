        "jsCode": "const session = $json.session;\nif (!session) throw new Error('NO_SESSION');\n\nconst tariff = String($json.tariff ?? ''); // убедись, что тариф уже выставлен\nif (!tariff) throw new Error('NO_TARIFF_IN_PAY_FLOW');\n\n// где хранится email — мы выбрали session.customer_email\nconst email = String(session.customer_email ?? '').trim();\n\nif (!email) {\n  // ✅ вот тут ставим флаг\n  session.awaiting_email = true;\n\n  // чтобы после ввода email можно было продолжить оплату\n  session.tariff_pending = tariff;\n\n  return [{\n    ...$json,\n    session,\n    need_email: true\n  }];\n}\n\nreturn [{\n  ...$json,\n  session,\n  need_email: false\n}];"
      },
