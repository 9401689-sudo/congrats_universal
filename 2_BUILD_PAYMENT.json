        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  \"amount\": {\n    \"value\": $json.tariff === '199' ? '199.00' : '149.00',\n    \"currency\": \"RUB\"\n  },\n  \"capture\": true,\n  \"confirmation\": {\n    \"type\": \"redirect\",\n    \"return_url\": \"https://t.me/razresheno_buro_bot\"\n  },\n  \"description\": `Электронная открытка №${$json.session.active_request_id}`,\n  \"metadata\": {\n    \"request_id\": String($json.session.active_request_id),\n    \"tg_user_id\": String($json.session.tg_user_id),\n    \"tariff\": String($json.tariff)\n  },\n  \"receipt\": {\n    \"customer\": {\n      \"email\": $json.session.customer_email\n    },\n    \"items\": [\n      {\n        \"description\": \"Электронная открытка (Бюро Разрешено)\",\n        \"quantity\": \"1.00\",\n        \"amount\": {\n          \"value\": $json.tariff === '199' ? '199.00' : '149.00',\n          \"currency\": \"RUB\"\n        },\n        \"vat_code\": 1,\n        \"payment_subject\": \"service\",\n        \"payment_mode\": \"full_payment\"\n      }\n    ]\n  }\n}\n}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
