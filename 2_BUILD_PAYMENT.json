{
  "name": "2_BUILD_PAYMENT",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const session = $json.session ?? {};\n\n// Postgres node\nconst pgOut = $node[\"PAY199__PG_GET_REQUEST1\"]?.json ?? {};\n\n// PG может вернуть:\n// { id: ... }\n// { request: {...} }\n// [{...}]\nlet req;\n\nif (Array.isArray(pgOut)) {\n  req = pgOut[0];\n} else if (pgOut.request) {\n  req = pgOut.request;\n} else {\n  req = pgOut;\n}\n\nif (!req) {\n  throw new Error(\"PG_GET_REQUEST returned empty\");\n}\n\nconst tariff = String(session.tariff_pending ?? \"\").trim();\nif (!tariff) throw new Error(\"tariff_pending missing in session\");\n\n\n// ---- variant из Redis ----\nconst redisOut = $node[\"REDIS_GET_SESSION_TZ_PENDING1\"]?.json ?? {};\nconst raw = redisOut.value ?? redisOut.data ?? redisOut.result ?? redisOut;\n\nif (!raw) throw new Error(\"Selected variant missing in Redis\");\n\nlet variant_snapshot;\n\nif (typeof raw === \"object\" && raw !== null) {\n  variant_snapshot = raw;\n} else {\n  const s = String(raw).trim();\n  variant_snapshot = JSON.parse(s);\n}\n\nconst initiator_name =\n  String(session.tg_first_name ?? \"\").trim() || \"Инициатор\";\n\nreturn [{\n  json: {\n    ...$json,\n    request_id: String(req.id),\n    tariff,\n    initiator_name,\n    variant_snapshot,\n    payment_payload: {\n      provider: \"yookassa\",\n      yk: {\n        tariff\n      },\n      request_id: String(req.id),\n      tg_user_id: String(session.tg_user_id),\n      initiator_name,\n      selected_variant_idx: Number(req.selected_variant_idx),\n      variant_snapshot\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        320
      ],
      "id": "0109cbee-f74b-489c-a787-61f24c37054c",
      "name": "FN_BUILD_YOOKASSA_PAYMENT_REQUEST"
