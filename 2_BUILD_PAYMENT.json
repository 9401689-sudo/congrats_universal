    {
      "parameters": {
        "jsCode": "// Ответ ЮKassa обычно лежит в $json (если n8n так настроен)\n// Иногда в $json.body. Подстрахуемся.\nconst resp = $json.body ?? $json;\n\nconst paymentId = resp.id;\nconst confirmationUrl = resp.confirmation?.confirmation_url;\nconst status = resp.status;\n\nif (!paymentId || !confirmationUrl) {\n  return [{\n    ok: false,\n    error_message: 'ЮKassa не вернула ссылку оплаты.',\n    debug: resp\n  }];\n}\n\nreturn [{\n  ...$json,\n  ok: true,\n  yk_payment_id: paymentId,\n  yk_status: status,\n  yk_confirmation_url: confirmationUrl\n}];"
      },
